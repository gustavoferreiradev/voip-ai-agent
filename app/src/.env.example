# ── FreeSWITCH ESL (VM com FS PBX) ──────────────────────────
FS_HOST=192.168.x.x          # IP da VM com FS PBX instalado
FS_ESL_PORT=8021
FS_ESL_PASSWORD=sua_senha_forte

# ── PostgreSQL local (CDRs e transcrições da IA) ─────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=voipai
DB_USER=voipai
DB_PASS=voipai

# ── Deepgram ─────────────────────────────────────────────────
DEEPGRAM_API_KEY=sua_chave_deepgram

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sua_chave_openai
TTS_VOICE=nova

# ── App ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ── Audio WebSocket (mod_audio_stream) ───────────────────────
# IP do servidor Node.js acessível pelo FreeSWITCH
# Em dev com Multipass: IP do host (gateway da VM = 10.197.3.1)
NODE_IP=10.197.3.1
AUDIO_WS_PORT=8090