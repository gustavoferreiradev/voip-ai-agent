    "@biomejs/biome": "^1.8.0"
  },
  "optionalDependencies": {
    "@biomejs/biome-linux-x64": "1.8.0",
    "@biomejs/biome-linux-arm64": "1.8.0",
    "@biomejs/biome-darwin-x64": "1.8.0",
    "@biomejs/biome-darwin-arm64": "1.8.0",
    "@biomejs/biome-win32-x64": "1.8.0"
